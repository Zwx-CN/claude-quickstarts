# Qwen 3.7 Plus or a compatible gateway.
# DashScope/OpenAI-compatible deployments commonly use /compatible-mode/v1/chat/completions.
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3.7-plus

# Provider split.
# Model provider controls which model API/prompt/parser family is used.
# Desktop provider controls where the Linux desktop runs.
# Deploy profile controls how the stack is copied and started.
CU_MODEL_PROVIDER=qwen
CU_DESKTOP_PROVIDER=docker
CU_DEPLOY_PROFILE=local-docker

# UTM VM deployment settings. Example:
# CU_UTM_SSH_TARGET=ubuntu@192.168.64.12
# CU_UTM_REMOTE_DIR=~/cn-linux-computer-use-demo
CU_UTM_SSH_TARGET=
CU_UTM_REMOTE_DIR=~/cn-linux-computer-use-demo

# Desktop/session defaults.
DISPLAY=:99
CU_SCREEN_WIDTH=1280
CU_SCREEN_HEIGHT=720
CU_MAX_STEPS=30
CU_TRACE_DIR=./experiments/traces
